# ─────────────────────────────────────────────────────────────
# Tender Intelligence Dashboard — environment variables
# Single source: tenders.infralens.in (pure-HTTP, runs on Vercel).
#   • Vercel  → set DATABASE_URL/DIRECT_URL + (optional) Upstash + secrets
#   • Local   → copy this file to `.env`
# ─────────────────────────────────────────────────────────────

# ── Supabase Postgres ────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string.
# DATABASE_URL = Transaction pooler (port 6543) — runtime queries.
# DIRECT_URL   = Session/direct connection (port 5432) — migrations.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Upstash Redis (optional, recommended on Vercel) ──────────
# Caches reads + the infralens PoW token across invocations. If unset, an
# in-memory cache is used (per-instance only).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Secret ───────────────────────────────────────────────────
# Protects GET /api/refresh (used by the Vercel cron). openssl rand -hex 32
# Set CRON_SECRET to the SAME value on Vercel — cron sends it as a Bearer token.
REFRESH_SECRET="change-me-to-a-long-random-string"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Collector tuning ─────────────────────────────────────────
# Skip the live API and use bundled seed data (offline/demo/CI).
COLLECTORS_USE_SEED_ONLY="false"
# Per-request timeout (ms) for infralens API calls.
COLLECTOR_TIMEOUT_MS="20000"
COLLECTOR_MAX_RETRIES="3"
COLLECTOR_RATE_LIMIT_MS="0"

LOG_LEVEL="info"
NODE_ENV="development"
